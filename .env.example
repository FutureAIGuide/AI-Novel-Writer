# Copy this file to .env and fill in your values.
# These environment variables are used as a fallback when no settings file exists.
# For full multi-provider support, use: novel-writer settings set-provider <provider> --api-key <key>

# OpenAI (default provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.8

# Output directory for saved stories
OUTPUT_DIR=stories

# Optional: Override the settings file location (default: ~/.config/ai-novel-writer/settings.json)
# AI_NOVEL_WRITER_SETTINGS=/path/to/custom/settings.json
